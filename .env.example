# meet-transcribe environment variables — sample
# Copy to .env and fill in real values. NEVER commit .env.
# In production, prefer /etc/meet-transcribe/env loaded by systemd EnvironmentFile.

# ---- DB ----
MT_DB_PASSWORD=CHANGE_ME

# ---- 服务密钥 (32 字节随机) ----
# 生成: python -c "import secrets; print(secrets.token_urlsafe(32))"
MT_SERVER_SECRET=CHANGE_ME

# ---- AES-GCM 主密钥 (32 字节 base64) ----
# 生成: python -c "import os, base64; print(base64.b64encode(os.urandom(32)).decode())"
MT_KMS_KEY=CHANGE_ME

# ---- 管理端点鉴权凭证 (32 字节随机) ----
MT_ADMIN_TOKEN=CHANGE_ME

# ---- 可选 ----
# MT_CONFIG_FILE=/etc/meet-transcribe/meet-transcribe.yaml
# 仅 Linux/CUDA 11.4+ 支持；Windows 不识别会发 UserWarning，开发机请去掉此行：
# PYTORCH_CUDA_ALLOC_CONF=expandable_segments:True
# HF_HOME=/var/lib/meet-transcribe/hf-cache
# 国内开发机如直连 huggingface.co 失败，可走镜像：
# HF_ENDPOINT=https://hf-mirror.com
# HF_HUB_ENABLE_HF_TRANSFER=0
